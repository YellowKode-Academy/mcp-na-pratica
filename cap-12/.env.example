# .env.example -- vai pro git sem valores reais
# Capitulo 12: Variaveis para deploy em producao

# Gere JWT_SECRET com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

SERPAPI_KEY=
MAX_RESULTADOS=10

LOG_FORMAT=json
LOG_LEVEL=INFO

# PORT e definido automaticamente pelo Railway
PORT=8000
